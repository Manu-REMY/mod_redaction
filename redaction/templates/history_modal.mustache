{{!
    @template mod_redaction/history_modal

    Modal for viewing version history.

    Example context (json):
    {}
}}
<div id="history-modal" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{#str}}version_history, redaction{{/str}}</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="history-content">
                <!-- Loaded via AJAX -->
            </div>
        </div>
    </div>
</div>
