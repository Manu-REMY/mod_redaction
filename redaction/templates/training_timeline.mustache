{{!
    @template mod_redaction/training_timeline

    Training timeline panel for the grading sidebar.
    Shows a horizontal chronological timeline of training attempts with
    interactive markers, sparkline, and detail panel.

    Context variables required for this template:
    * hasattempts - Boolean
    * attemptcount - Number of attempts
    * attempts - Array of attempt objects:
        * index - Zero-based index
        * num - 1-based attempt number
        * positionpercent - Position on timeline (0-100)
        * gradelevel - Grade level string (excellent/good/medium/low/pending/failed)
        * gradestr - Formatted grade string
        * datestr - Full date string
        * dateshort - Short date string
        * status - Evaluation status
    * timelinestartstr - Start date label
    * timelineendstr - End date label
    * elapsedpercent - Elapsed time percentage
    * hasfinalsubmission - Boolean
    * finalpositionpercent - Final submission position
    * finaldate - Final submission date string
    * hasdeadline - Boolean
    * deadlinedatestr - Deadline date string

    Example context (json):
    {
        "hasattempts": true,
        "attemptcount": 3,
        "attempts": [
            {"index": 0, "num": 1, "positionpercent": 25, "gradelevel": "low", "gradestr": "8.0/20", "datestr": "15 Jan 2026", "dateshort": "15/01 14:30", "status": "completed"}
        ],
        "timelinestartstr": "15 Jan",
        "timelineendstr": "10 Feb",
        "elapsedpercent": 60,
        "hasfinalsubmission": false,
        "hasdeadline": true,
        "deadlinedatestr": "10 Feb 2026"
    }
}}
<div class="mod_redaction-grading-form-container mod_redaction-training-timeline-container" id="training-timeline">
    <h5 class="mod_redaction-training-timeline-title">
        &#128202; {{#str}}training_timeline_title, redaction{{/str}}
        {{#hasattempts}}
            <span class="mod_redaction-training-timeline-badge">{{attemptcount}}</span>
        {{/hasattempts}}
    </h5>

    {{^hasattempts}}
        <p class="text-muted" style="font-size: 13px; font-style: italic; margin: 0;">
            {{#str}}training_timeline_no_data, redaction{{/str}}
        </p>
    {{/hasattempts}}

    {{#hasattempts}}
        {{! Trend indicator - populated by JS }}
        <div class="mod_redaction-training-timeline-trend" id="timeline-trend">
            <span class="mod_redaction-trend-label">{{#str}}training_timeline_progress, redaction{{/str}} :</span>
            <span class="mod_redaction-trend-arrow mod_redaction-trend-flat"></span>
            <span class="mod_redaction-trend-summary"></span>
        </div>

        {{! Timeline track }}
        <div class="mod_redaction-training-timeline-track-wrapper">
            <div class="mod_redaction-timeline-time-labels">
                <span class="mod_redaction-timeline-time-start">{{timelinestartstr}}</span>
                <span class="mod_redaction-timeline-time-end">{{timelineendstr}}</span>
            </div>

            <div class="mod_redaction-timeline-track" id="timeline-track"
                 role="slider"
                 aria-label="{{#str}}training_timeline_title, redaction{{/str}}"
                 aria-valuemin="1"
                 aria-valuemax="{{attemptcount}}"
                 tabindex="0">

                {{! Background bar }}
                <div class="mod_redaction-timeline-track-bg"></div>

                {{! Elapsed time fill }}
                <div class="mod_redaction-timeline-track-elapsed" style="width: {{elapsedpercent}}%"></div>

                {{! Attempt markers }}
                {{#attempts}}
                <button type="button"
                        class="mod_redaction-timeline-marker mod_redaction-timeline-marker-{{gradelevel}}"
                        style="left: {{positionpercent}}%"
                        data-attempt-index="{{index}}"
                        data-grade="{{gradestr}}"
                        title="{{#str}}training_timeline_attempt, redaction, {{num}}{{/str}} - {{gradestr}} - {{dateshort}}">
                    <span class="mod_redaction-marker-dot"></span>
                    <span class="mod_redaction-marker-label">{{num}}</span>
                </button>
                {{/attempts}}

                {{! Final submission marker }}
                {{#hasfinalsubmission}}
                <div class="mod_redaction-timeline-marker mod_redaction-timeline-marker-final"
                     style="left: {{finalpositionpercent}}%"
                     title="{{#str}}training_timeline_final, redaction{{/str}} - {{finaldate}}">
                    <span class="mod_redaction-marker-flag">&#9873;</span>
                </div>
                {{/hasfinalsubmission}}

                {{! Draggable cursor }}
                <div class="mod_redaction-timeline-cursor" id="timeline-cursor">
                    <div class="mod_redaction-cursor-handle"></div>
                </div>

                {{! Deadline marker }}
                {{#hasdeadline}}
                <div class="mod_redaction-timeline-deadline-marker"
                     style="left: 100%"
                     title="Deadline: {{deadlinedatestr}}">
                    <span class="mod_redaction-deadline-line"></span>
                </div>
                {{/hasdeadline}}
            </div>

            {{! Sparkline SVG }}
            <div class="mod_redaction-timeline-sparkline" id="timeline-sparkline">
                <svg viewBox="0 0 300 40" preserveAspectRatio="none" class="mod_redaction-sparkline-svg">
                    <polyline class="mod_redaction-sparkline-line" points="" fill="none"/>
                </svg>
            </div>
        </div>

        {{! Detail panel - populated by JS on marker selection }}
        <div class="mod_redaction-timeline-detail-panel" id="timeline-detail" style="display:none;">
            <div class="mod_redaction-detail-header">
                <span class="mod_redaction-detail-attempt-num" id="detail-attempt-num"></span>
                <span class="mod_redaction-detail-date" id="detail-date"></span>
                <span class="mod_redaction-detail-grade" id="detail-grade"></span>
            </div>
            <div class="mod_redaction-detail-criteria" id="detail-criteria"></div>
            <div class="mod_redaction-detail-feedback" id="detail-feedback"></div>
        </div>

        {{! No-JS fallback: simple list }}
        <div class="mod_redaction-training-timeline-fallback" id="timeline-fallback">
            {{#attempts}}
            <div class="mod_redaction-timeline-fallback-item">
                <span>{{#str}}training_timeline_attempt, redaction, {{num}}{{/str}} - {{dateshort}}</span>
                <span class="mod_redaction-ai-level-{{gradelevel}}" style="font-weight: 600; padding: 2px 8px; border-radius: 10px; font-size: 12px;">{{gradestr}}</span>
            </div>
            {{/attempts}}
        </div>
    {{/hasattempts}}
</div>
