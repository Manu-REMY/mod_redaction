{{!
    @template mod_redaction/submission_panel

    Student submission display panel.

    Context variables required for this template:
    * hassubmission - Boolean
    * hascontent - Boolean
    * issubmitted - Boolean
    * isdraft - Boolean
    * submissionid - Submission ID
    * titre - Submission title
    * contenu - Formatted content HTML
    * timesubmitted - Formatted date
    * timemodified - Formatted date
    * wordcount - Word count
    * charcount - Character count
    * cangrade - Boolean
    * canviewhistory - Boolean

    Example context (json):
    {
        "hassubmission": true,
        "hascontent": true,
        "issubmitted": true,
        "submissionid": 1,
        "titre": "My Essay",
        "contenu": "<p>Content here</p>",
        "wordcount": 150,
        "charcount": 800
    }
}}
<div class="mod_redaction-submission-content">
    {{^hascontent}}
        <div class="mod_redaction-status-bar mod_redaction-no-submission">
            &#10060; {{#str}}no_submission, redaction{{/str}}
        </div>
    {{/hascontent}}

    {{#hascontent}}
        {{#issubmitted}}
            <div class="mod_redaction-status-bar mod_redaction-submitted">
                &#9989; {{#str}}status_submitted, redaction{{/str}}
                <span style="margin-left: auto; font-size: 13px;">
                    {{#str}}submitted_on, redaction, {{timesubmitted}}{{/str}}
                </span>
                {{#cangrade}}
                    <button type="button" class="mod_redaction-unlock-btn" onclick="unlockSubmission({{submissionid}})">
                        &#128275; {{#str}}unlock_submission, redaction{{/str}}
                    </button>
                {{/cangrade}}
            </div>
        {{/issubmitted}}
        {{^issubmitted}}
            <div class="mod_redaction-status-bar mod_redaction-draft">
                &#128221; {{#str}}status_draft, redaction{{/str}}
                <span style="margin-left: auto; font-size: 13px;">
                    {{#str}}lastmodified, redaction{{/str}}: {{timemodified}}
                </span>
            </div>
        {{/issubmitted}}

        {{#titre}}
            <div class="mod_redaction-content-title">{{{titre}}}</div>
        {{/titre}}

        <div class="mod_redaction-content-display">
            {{{contenu}}}
        </div>

        <div class="mod_redaction-word-count">
            {{#str}}word_count, redaction, {{wordcount}}{{/str}} |
            {{#str}}char_count, redaction, {{charcount}}{{/str}}
            {{#canviewhistory}}
                | <a href="#" class="mod_redaction-history-link" onclick="showHistory({{submissionid}}); return false;">
                    &#128220; {{#str}}version_history, redaction{{/str}}
                </a>
            {{/canviewhistory}}
        </div>

        {{#hastraining}}
        <div style="margin-top: 10px; padding: 8px 14px; background: linear-gradient(135deg, #ebf4ff 0%, #e8f0fe 100%); border: 1px solid #bee3f8; border-radius: 8px; font-size: 13px; display: flex; align-items: center; gap: 8px;">
            <span>&#127891;</span>
            <span style="font-weight: 600; color: #2b6cb0;">
                {{#str}}training_attempts_count, redaction, {{trainingcount}}{{/str}}
            </span>
        </div>
        {{/hastraining}}
    {{/hascontent}}
</div>
